#!/bin/sh

set -eu

message_file="$1"
subject_line="$(sed -e '/^#/d' -e '/^[[:space:]]*$/d' "$message_file" | head -n 1)"

if [ -z "$subject_line" ]; then
    printf '%s\n' 'Commit message must include a subject line.' >&2
    exit 1
fi

case "$subject_line" in
    Merge\ *|Revert\ *)
        exit 0
        ;;
esac

subject_length=${#subject_line}

if [ "$subject_length" -gt 72 ]; then
    printf '%s\n' 'Commit subject must be 72 characters or fewer.' >&2
    exit 1
fi

if printf '%s' "$subject_line" | grep -Eq '\.$'; then
    printf '%s\n' 'Commit subject must not end with a period.' >&2
    exit 1
fi

if printf '%s' "$subject_line" | grep -Eqi '\b(phase|wip|tmp|temp|misc|stuff)\b'; then
    printf '%s\n' 'Commit subject must describe the engineering outcome, not a placeholder.' >&2
    exit 1
fi

if ! printf '%s' "$subject_line" | grep -Eq '^(Add|Align|Build|Configure|Document|Fix|Harden|Improve|Implement|Introduce|Migrate|Refactor|Remove|Rename|Set up|Simplify|Standardize|Tighten|Update)\b'; then
    printf '%s\n' 'Commit subject must start with an approved imperative verb.' >&2
    exit 1
fi
